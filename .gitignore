<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Suprimento Selbetti - Localiza-Seminovos</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f7f6; display: flex; justify-content: center; padding: 40px; }
        .card { background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); width: 100%; max-width: 500px; }
        h2 { color: #008000; text-align: center; margin-bottom: 25px; }
        .search-box { position: relative; margin-bottom: 20px; }
        input { width: 100%; padding: 12px; border: 2px solid #ddd; border-radius: 6px; font-size: 16px; outline: none; transition: border-color 0.3s; box-sizing: border-box; }
        input:focus { border-color: #008000; }
        button { width: 100%; padding: 12px; background-color: #008000; color: white; border: none; border-radius: 6px; font-size: 16px; cursor: pointer; font-weight: bold; }
        button:hover { background-color: #006400; }
        #resultado { margin-top: 25px; display: none; border-top: 1px solid #eee; padding-top: 20px; }
        .info-group { margin-bottom: 12px; }
        .label { font-weight: bold; color: #666; font-size: 12px; text-transform: uppercase; display: block; }
        .value { color: #333; font-size: 15px; display: block; margin-top: 2px; }
        .erro { color: #d32f2f; text-align: center; font-weight: bold; display: none; margin-top: 15px; }

        img {
            width: 100%;
            max-height: 200px;
            object-fit: contain;
            margin-top: 10px;
            border-radius: 8px;
        }
    </style>
</head>
<body>

<div class="card">
    <h2>Confira seu Suprimento</h2>
    
    <div class="search-box">
        <input type="text" id="inputSelb" placeholder="Digite a SELB (Confira seu Suprimento)" onkeyup="if(event.keyCode===13) buscar()">
    </div>
    <button onclick="buscar()">BUSCAR INFORMAÇÕES</button>

    <div id="erroMsg" class="erro">SELB não encontrada na base de dados.</div>

    <div id="resultado">
        <div class="info-group"><span class="label">AGÊNCIA</span><span id="resDivisao" class="value"></span></div>
        <div class="info-group"><span class="label">SIGLA</span><span id="resAgencia" class="value"></span></div>
        <div class="info-group"><span class="label">SELB</span><span id="resSelb" class="value"></span></div>
        <div class="info-group"><span class="label">MODELO</span><span id="resModelo" class="value"></span></div>
        <div class="info-group"><span class="label">SÉRIE DO EQUIPAMENTO</span><span id="resSerie" class="value"></span></div>
        <div class="info-group"><span class="label">ENDEREÇO</span><span id="resEndereco" class="value"></span></div>

        <!-- IMAGEM -->
        <div class="info-group">
            <span class="label">IMAGEM DO MODELO</span>
            <img id="imgModelo" src="" alt="Imagem da impressora">
        </div>
    </div>
</div>

<script>
    const baseDados = [
        {selb: "3Y97", divisao: "SEMINOVOS", agencia: "LJOPI", modelo: "MX 632", serie: "7020405204HZH", endereco: "AV. DR.OTAVIANO PEREEIRA MENDES, 634, Liberdade, ITU/SP - ITU"},
        {selb: "3Y62", divisao: "SEMINOVOS", agencia: "LJOPI", modelo: "MX 632", serie: "7020405204HYW", endereco: "AV. DR.OTAVIANO PEREEIRA MENDES, 634, Liberdade, ITU/SP - ITU"},
        {selb: "04VU", divisao: "LOCALIZA", agencia: "RDMAB", modelo: "MX611", serie: "701631HH015XK", endereco: "Rua João Pessoa, Belo Horizonte"},
        {selb: "IBT3", divisao: "LOCALIZA", agencia: "BSI02", modelo: "MX522", serie: "7017817100YTH", endereco: "Brasília"},
        {selb: "05UN", divisao: "LOCALIZA", agencia: "RDMAB", modelo: "MX 611", serie: "701667HH08LD8", endereco: "Rio Verde"},
        {selb: "06GN", divisao: "Localiza", agencia: "ACZGR", modelo: "MX622", serie: "7018949308CZV", endereco: "Guarulhos"}
    ];

    // MAPA DE IMAGENS
    const imagensModelos = {
        "MX632": "imagens/mx632.png",
        "MX611": "imagens/mx611.png",
        "MX522": "imagens/mx522.png",
        "MX622": "imagens/mx622.png"
    };

    function buscar() {
        const busca = document.getElementById('inputSelb').value.trim().toUpperCase();
        const resultadoDiv = document.getElementById('resultado');
        const erroDiv = document.getElementById('erroMsg');

        const item = baseDados.find(i => i.selb.toUpperCase() === busca);

        if (item) {
            document.getElementById('resDivisao').innerText = item.divisao;
            document.getElementById('resAgencia').innerText = item.agencia;
            document.getElementById('resModelo').innerText = item.modelo;
            document.getElementById('resSerie').innerText = item.serie;
            document.getElementById('resSelb').innerText = item.selb;
            document.getElementById('resEndereco').innerText = item.endereco;

            // IMAGEM
            const img = document.getElementById('imgModelo');

            // normaliza modelo (remove espaço)
            const modeloNormalizado = item.modelo.replace(/\s/g, "");

            const caminhoImagem = imagensModelos[modeloNormalizado];

            if (caminhoImagem) {
                img.src = caminhoImagem;
                img.style.display = "block";
            } else {
                img.style.display = "none";
            }

            resultadoDiv.style.display = 'block';
            erroDiv.style.display = 'none';
        } else {
            resultadoDiv.style.display = 'none';
            erroDiv.style.display = 'block';
        }
    }
</script>

</body>
</html>
